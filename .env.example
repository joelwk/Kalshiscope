# xAI Grok Configuration
# Get your API key from https://console.x.ai
XAI_API_KEY=your_xai_api_key_here
GROK_MODEL=grok-4-1-fast-reasoning
GROK_MODEL_DEEP=grok-4.20-beta-0309-reasoning
# xAI timeout for creating requests and responses
XAI_CLIENT_TIMEOUT_SECONDS=120
# Hard timeout for a single streamed Grok response
GROK_STREAM_TIMEOUT_SECONDS=120
# Total retry budget per market analysis call (must exceed stream timeout for retry headroom)
GROK_ANALYSIS_MAX_BUDGET_SECONDS=180

# Kalshi API Configuration
KALSHI_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=your_kalshi_api_key_id_here
KALSHI_PRIVATE_KEY_PATH=kalshi-scope.txt
# Attempt server-side close-time filtering on market fetch (auto-fallback if unsupported)
KALSHI_SERVER_SIDE_FILTERS_ENABLED=true
# Hard cap on paginated market fetch requests per cycle (0 = unlimited; use MARKET_MAX_CLOSE_DAYS to scope)
KALSHI_MAX_FETCH_PAGES=10

# Risk Management Configuration
HIGH_CONFIDENCE_POSITION_OVERRIDE=0.85
# Minimum confidence threshold (0.0 to 1.0) to execute trades
MIN_CONFIDENCE=0.50
# Confidence-gate override when edge and evidence are both strong
CONFIDENCE_GATE_EDGE_OVERRIDE_ENABLED=true
CONFIDENCE_GATE_MIN_EDGE=0.10
CONFIDENCE_GATE_MIN_EVIDENCE_QUALITY=0.70
CONFIDENCE_GATE_OVERRIDE_MIN_CONFIDENCE=0.62
# Hard floor: skip execution when evidence quality is below this threshold
MIN_EVIDENCE_QUALITY_FOR_TRADE=0.72
SCORE_LOW_INFO_PENALTY_THRESHOLD=0.60
SCORE_LOW_INFO_PENALTY_BASE=0.12
# Weather-specific evidence floor (applied when market family is weather)
WEATHER_MIN_EVIDENCE_QUALITY=0.50
# Minimum evidence quality for fallback-edge trades (no bookmaker odds found).
# Bypassed when evidence_basis=direct AND verifiable source signal AND evidence_quality>=0.65
GROK_FALLBACK_MIN_EVIDENCE_QUALITY=0.45
# Allow high-confidence, high-edge, source-verifiable analyses to bypass fallback evidence caps
EVIDENCE_QUALITY_HIGH_CONFIDENCE_OVERRIDE=true
# Cap confidence for proxy-evidence fallback-edge trades
GROK_PROXY_CONFIDENCE_CAP=0.78
# Cap confidence when low-information + fallback edge
GROK_LOW_INFO_CONFIDENCE_CAP=0.70
# Evidence threshold below which the bot abstains entirely
GROK_ABSTAIN_EVIDENCE_THRESHOLD=0.35
# Minimum market liquidity in USDC to consider
MIN_LIQUIDITY_USDC=15.0
# Polling interval in seconds (how often to check markets)
POLL_INTERVAL_SEC=300

# Edge gating
# Global minimum edge required for any trade
MIN_EDGE=0.07
# Outcomes below this probability face a higher edge requirement
LOW_PRICE_THRESHOLD=0.50
VERY_LOW_PRICE_THRESHOLD=0.25
# Minimum edge required for outcomes below LOW_PRICE_THRESHOLD
LOW_PRICE_MIN_EDGE=0.15
# Minimum edge required for outcomes below VERY_LOW_PRICE_THRESHOLD
VERY_LOW_PRICE_MIN_EDGE=0.25
# Near-coinflip zone: prices in this band face higher edge + pre-analysis penalty
COINFLIP_PRICE_LOWER=0.48
COINFLIP_PRICE_UPPER=0.52
# Minimum edge when edge_source=fallback (no external odds found)
FALLBACK_EDGE_MIN_EDGE=0.15
# Minimum edge for weather markets
WEATHER_MIN_EDGE=0.12
# Stricter minimum edge when edge_source=fallback on weather markets
WEATHER_FALLBACK_EDGE_MIN_EDGE=0.18

# Market Filtering
# Comma-separated list of allowed categories (empty = all)
MARKET_CATEGORIES_ALLOWLIST=
# Comma-separated list of blocked categories (matches raw Kalshi category AND inferred market family)
MARKET_CATEGORIES_BLOCKLIST=
# Comma-separated list of blocked inferred market families (weather, crypto, speech, etc)
MARKET_FAMILY_BLOCKLIST=
# Skip noisy market families that consistently produce low-information analysis
MARKET_TICKER_BLOCKLIST_PREFIXES=
# Block narrow crypto bin markets (e.g., BTC/ETH range bins) that are usually low-edge
CRYPTO_BIN_MARKET_BLOCKLIST_ENABLED=true
# Minimum trailing 24h volume required (0 disables this filter)
MIN_VOLUME_24H=10
MIN_OPEN_INTEREST=25
# Skip extreme YES-priced markets to avoid low-information tails
EXTREME_YES_PRICE_LOWER=0.02
EXTREME_YES_PRICE_UPPER=0.98
# Hard reject near-certain markets where execution/edge is typically poor
MIN_TRADEABLE_IMPLIED_PRICE=0.12
MAX_TRADEABLE_IMPLIED_PRICE=0.95
# Collapse large event ladders (e.g., crypto range brackets)
LADDER_COLLAPSE_THRESHOLD=3
MAX_BRACKETS_PER_EVENT=3

# Execution Mode
# Set to false to execute real trades (use with caution!)
DRY_RUN=false
POSITION_SYNC_ENABLED=true
POSITION_SYNC_INTERVAL_CYCLES=3
# Refresh market data before order submission; when refresh fails, a lenient fallback
# allows proceeding with stale data (up to 2.5x MAX_MARKET_DATA_AGE_SECONDS) when
# evidence_basis is direct and score passes the gate threshold.
PRE_ORDER_MARKET_REFRESH=true
MAX_MARKET_DATA_AGE_SECONDS=120
ORDERBOOK_PRECHECK_ENABLED=true
ORDERBOOK_PRECHECK_MIN_CONFIDENCE=0.75
ORDERBOOK_MIN_RESTING_VOLUME=3
ORDER_PRICE_IMPROVEMENT_CENTS=1
ORDER_DEFAULT_TIF=gtc
# Do not submit orders at extreme unfillable prices
ORDER_SUBMISSION_MIN_PRICE=0.03
ORDER_SUBMISSION_MAX_PRICE=0.97
# Retry at market price when limit order is canceled unfilled (high-confidence only)
ORDER_FALLBACK_TO_MARKET=true
ORDER_FALLBACK_MIN_CONFIDENCE=0.85
ORDER_FALLBACK_MIN_LIQUIDITY_USDC=200

# Bet sizing
MIN_BET_USDC=2
MAX_BET_USDC=4

# Position limits
# Max single-market exposure as fraction of available bankroll (0.15 = 15%)
MAX_POSITION_PCT_OF_BANKROLL=0.15
# Block position re-add when market price hasn't moved enough since last entry
MIN_PRICE_MOVE_FOR_READD=0.05

# Only bet on markets closing within this window
MARKET_MIN_CLOSE_DAYS=0
MARKET_MAX_CLOSE_DAYS=7

# Score gate mode: off | shadow | active
SCORE_GATE_MODE=active
SCORE_GATE_THRESHOLD=0.32
SCORE_REPEATED_ANALYSIS_PENALTY_BASE=0.20
SCORE_REPEATED_ANALYSIS_PENALTY_START_COUNT=1
SCORE_CONFIDENCE_CALIBRATION_FLOOR=0.55
SCORE_CONFIDENCE_CALIBRATION_PENALTY_SCALE=0.10
SCORE_GATE_THRESHOLD_DIRECT_HIGH_QUALITY=0.25
# Confidence shrinkage toward neutral (direct evidence gets 1.5x factor with raised floor;
# definitive outcomes with likelihood_ratio>=10 get 2.5x factor, preserving near-raw confidence)
CONFIDENCE_SHRINKAGE_FLOOR=0.52
CONFIDENCE_SHRINKAGE_FACTOR=0.40
SCORE_FALLBACK_EDGE_PENALTY_BASE=0.07
SCORE_COMPUTED_EDGE_BONUS=0.03
SCORE_PROXY_EVIDENCE_PENALTY_BASE=0.09
MENTION_MARKET_SCORE_PENALTY=0.10
PRE_ANALYSIS_OPPORTUNITY_ENABLED=true
PRE_ANALYSIS_OPPORTUNITY_MIN_SCORE=0.55
PRE_ANALYSIS_NON_ACTIONABLE_STREAK_PENALTY=0.15
PRE_ANALYSIS_ANALYSIS_COUNT_PENALTY=0.05
PRE_ANALYSIS_FALLBACK_FAMILY_RATE_THRESHOLD=0.80
PRE_ANALYSIS_FALLBACK_FAMILY_PENALTY=0.12
PRE_ANALYSIS_FALLBACK_FAMILY_MIN_SAMPLES=20
PRE_ANALYSIS_HISTORICAL_FAMILY_MIN_SAMPLES=10
PRE_ANALYSIS_HISTORICAL_FAMILY_WIN_RATE_THRESHOLD=0.45
PRE_ANALYSIS_HISTORICAL_FAMILY_PENALTY=0.12
PRE_ANALYSIS_HISTORICAL_FAMILY_PNL_MIN_SAMPLES=20
PRE_ANALYSIS_HISTORICAL_FAMILY_PNL_THRESHOLD=-10
PRE_ANALYSIS_HISTORICAL_FAMILY_PNL_PENALTY=0.10
# Pre-analysis: post-event markets (close_time in past 0-6h) get +0.10 bonus to
# prioritize definitive-outcome opportunities; fallback-family penalty is halved
# when the family has positive PnL and >55% win rate.
# Pre-analysis hard rejection: stop re-analyzing hopeless markets sooner
PRE_ANALYSIS_HARD_REJECTION_ENABLED=true
PRE_ANALYSIS_HARD_REJECTION_MIN_STREAK=3
PRE_ANALYSIS_HARD_REJECTION_MIN_ANALYSES=5
PRE_ANALYSIS_HARD_REJECTION_FAMILIES=speech,music,generic,crypto,weather
# Block families with zero historical action rate
PRE_ANALYSIS_ZERO_ACTION_FAMILY_BLOCK_ENABLED=true
PRE_ANALYSIS_ZERO_ACTION_FAMILY_MIN_SAMPLES=20
# Severe negative PnL thresholds
PRE_ANALYSIS_HISTORICAL_FAMILY_PNL_SEVERE_THRESHOLD=-15.0
PRE_ANALYSIS_HISTORICAL_FAMILY_PNL_SEVERE_PENALTY=0.15
# Crypto short-circuit: skip expensive Grok calls on historically unprofitable crypto
PRE_ANALYSIS_CRYPTO_NEGATIVE_PNL_BLOCK_ENABLED=true
PRE_ANALYSIS_CRYPTO_NEGATIVE_PNL_THRESHOLD=0.0
PRE_ANALYSIS_CRYPTO_FALLBACK_RATE_BLOCK_THRESHOLD=0.55
PRE_ANALYSIS_CRYPTO_MIN_SAMPLES=20
# Additional score penalty for weather-market uncertainty
WEATHER_SCORE_PENALTY=0.12

# Parallel analysis
PARALLEL_ANALYSIS_ENABLED=true
ANALYSIS_MAX_WORKERS=3
# Hard cap on number of markets analyzed per cycle
MAX_MARKETS_PER_CYCLE=6
# When best pre-analysis score is below this, reduce candidate cap
PRE_ANALYSIS_MUST_ANALYZE_THRESHOLD=0.50
PRE_ANALYSIS_REDUCED_MAX_CANDIDATES=3
# Cap weather analysis slots to bias toward fewer, better opportunities
MAX_WEATHER_CANDIDATES_PER_CYCLE=1
# Cap crypto analysis slots to reduce correlated threshold over-trading
MAX_CRYPTO_CANDIDATES_PER_CYCLE=2
MAX_SPEECH_CANDIDATES_PER_CYCLE=1
MAX_MUSIC_CANDIDATES_PER_CYCLE=1
# Stop further analysis attempts after repeated consecutive xAI provider failures
XAI_CIRCUIT_BREAKER_MAX_FAILURES=3
# Maximum number of executed trades per cycle (capital concentration)
MAX_TRADES_PER_CYCLE=5
# Per-event concentration cap (e.g. max 2 bets on the same MLB game)
MAX_BETS_PER_EVENT=2
# Daily risk guardrails (reset at midnight UTC)
MAX_TRADES_PER_DAY=15
MAX_DAILY_DRAWDOWN_USDC=30.0

# Phase 3: Bayesian + LMSR + Kelly
BAYESIAN_ENABLED=false
# Skip Bayesian update count when reasoning hash hasn't changed between cycles
BAYESIAN_SKIP_STALE_UPDATES=true
LMSR_ENABLED=false
KELLY_SIZING_ENABLED=false

# Bayesian
BAYESIAN_PRIOR_DEFAULT=0.50
BAYESIAN_MIN_UPDATES_FOR_TRADE=1
# Clamp posterior to prevent runaway confidence (e.g. 0.999+)
BAYESIAN_MAX_POSTERIOR=0.97
# Cap posterior uplift above raw model confidence
BAYESIAN_MAX_CONFIDENCE_BOOST=0.15

# LMSR (execution-aware gate)
LMSR_LIQUIDITY_PARAM_B=100000
LMSR_MIN_INEFFICIENCY=0.05

# Kelly
KELLY_FRACTION_DEFAULT=0.25
KELLY_FRACTION_SHORT_HORIZON_HOURS=1
KELLY_FRACTION_SHORT_HORIZON=0.10
# Weather Kelly multiplier applied to horizon-selected Kelly fraction
KELLY_FRACTION_WEATHER=0.50
KELLY_ALLOW_MIN_BET_FLOOR_UPSCALE=false
# Kelly min-bet handling policy: skip | floor | fallback_edge_scaling
KELLY_MIN_BET_POLICY=fallback_edge_scaling
KELLY_MIN_BANKROLL_USDC=40

# Throughput / cadence
REANALYSIS_COOLDOWN_HOURS=6
URGENT_REANALYSIS_COOLDOWN_HOURS=1
URGENT_REANALYSIS_DAYS_BEFORE_CLOSE=1

# API cost estimation (per 1K tokens) for cycle receipts and analytics
# Set to your actual xAI model pricing (check console.x.ai for current rates)
API_COST_INPUT_PER_1K_TOKENS_USD=0.003
API_COST_OUTPUT_PER_1K_TOKENS_USD=0.015

# Optional: turn off outside calibration sessions
CALIBRATION_MODE_ENABLED=false

# Confidence caps by category
MAX_GLOBAL_CONFIDENCE=0.85
MAX_SPORTS_CONFIDENCE=0.80
MAX_ESPORTS_CONFIDENCE=0.75
MAX_WEATHER_CONFIDENCE=0.80
MAX_INDEX_CONFIDENCE=0.70
MAX_COMMODITY_CONFIDENCE=0.78
MAX_CRYPTO_CONFIDENCE=0.80
MAX_SPEECH_CONFIDENCE=0.65

# Weather research profile
WEATHER_ALLOWED_DOMAINS=weather.gov,forecast.weather.gov,noaa.gov,tropicaltidbits.com,wunderground.com
WEATHER_ALLOWED_X_HANDLES=NWS,NWSSPC,NHC_Atlantic,NWSChicago,NWSNewYorkNY,NWSLosAngeles,NWSHouston,NWSMiami,weatherchannel

# Speech/event research profile (word-mention markets)
SPEECH_ALLOWED_DOMAINS=c-span.org,youtube.com,whitehouse.gov,pm.gc.ca,parl.ca,politico.com,reuters.com,apnews.com
SPEECH_ALLOWED_X_HANDLES=CSPAN,WhiteHouse,POTUS,CanadianPM,Reuters,AP,politico,CBCNews,BBCWorld,WSJ

# Music/streaming research profile
MUSIC_ALLOWED_DOMAINS=billboard.com,hitsdailydouble.com,luminate.com,spotifycharts.com,chartmasters.org
MUSIC_ALLOWED_X_HANDLES=Billboard,SpotifyCharts,LuminateData,HitsDailyDouble
