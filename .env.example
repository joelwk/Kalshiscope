# xAI Grok Configuration
# Get your API key from https://console.x.ai
XAI_API_KEY=xai-
GROK_MODEL=grok-4-1-fast-reasoning

# PredictBase API Configuration
# API base URL for PredictBase
PREDICTBASE_API_BASE_URL=https://api.predictbase.app
# Optional: API key if required by PredictBase
PREDICTBASE_API_KEY=
# Header name for API key (default: x-api-key)
PREDICTBASE_API_KEY_HEADER=x-api-key
# Prefix for API key (empty for x-api-key header)
PREDICTBASE_API_KEY_PREFIX=

# Base Network Configuration (Chain ID 8453)
# Shared Alchemy RPC URL (you can replace with your own)
ALCHEMY_RPC_URL=
# Your wallet private key (keep secure!)
WALLET_PRIVATE_KEY=
# Base mainnet chain ID
CHAIN_ID=8453
# USDC token address on Base mainnet
USDC_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# PredictBase contract address
PREDICTBASE_CONTRACT_ADDRESS=0xaeA742f80922f7C94B8FD91686c9dFbDFE90d9E6

# Risk Management Configuration
HIGH_CONFIDENCE_POSITION_OVERRIDE=0.85
# Minimum confidence threshold (0.0 to 1.0) to execute trades
MIN_CONFIDENCE=0.65
# Minimum market liquidity in USDC to consider
MIN_LIQUIDITY_USDC=50.0
# Polling interval in seconds (how often to check markets)
POLL_INTERVAL_SEC=300
# Score gate mode: off | shadow | active
# Recommended production setting after validation: active
SCORE_GATE_MODE=active

# Market Filtering
# Comma-separated list of allowed categories (empty = all)
MARKET_CATEGORIES_ALLOWLIST=
# Comma-separated list of blocked categories
MARKET_CATEGORIES_BLOCKLIST=

# Execution Mode
# Safe default: true = no real orders are submitted
DRY_RUN=true
# Safe default: do not submit token approvals automatically
AUTO_APPROVE_USDC=false
# Safe default: do not execute on-chain transactions
EXECUTE_ONCHAIN=false

# USDC Configuration
# Decimals for USDC (6 for standard USDC)
USDC_DECIMALS=6

# Bet sizing
MIN_BET_USDC=1
MAX_BET_USDC=3

# Only bet on markets closing in this window (days from now)
MARKET_MIN_CLOSE_DAYS=0
MARKET_MAX_CLOSE_DAYS=7
